# Root level gitignore for SmolPC LibreOffice repository

# Dependencies
node_modules/
package-lock.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
**/.venv/
**/venv/
*.egg-info/
.pytest_cache/

# Rust/Tauri Build Outputs
**/target/
**/gen/
**/*.rs.bk
*.pdb

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
dist/
dist-ssr/
build/
.svelte-kit/

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Temporary files
*.tmp
*.temp
.cache/

# Test coverage
coverage/
*.lcov

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Yarn
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Old projects (kept locally for reference)
LibreOfficeAI/
libre-office-mcp/
